# OpenRouter API key — get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Primary model for vision (food recognition)
VISION_MODEL=minimax/minimax-m3

# Fallback models (comma-separated, in priority order)
FALLBACK_MODELS=google/gemini-2.5-flash,openai/gpt-4o-mini

# Optional: site attribution for OpenRouter rankings
SITE_URL=https://calorieapp.app
SITE_NAME=CalorieApp